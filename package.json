    "@types/file-saver": "^2.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",

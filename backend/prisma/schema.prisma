generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClinicPlan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum UserRole {
  ADMIN
  CLINIC_ADMIN
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum WaitlistStatus {
  WAITING
  OFFERED
  RESPONDED
  CONVERTED
  CANCELLED
}

enum ReminderType {
  BOOKING_CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  REMINDER_1H
  WAITLIST_OFFER
}

model Clinic {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  phone            String        @unique
  plan             ClinicPlan    @default(STARTER)
  stripeCustomerId String?       @unique
  // Short human-friendly code a patient sends (or a QR pre-fills) to reach THIS
  // clinic on the shared platform WhatsApp number. Lets every clinic onboard with
  // zero Meta setup — they just share their code/QR. Unique across clinics.
  joinCode         String?       @unique
  createdAt        DateTime      @default(now())

  // A SANDBOX clinic is a throwaway twin of a real one, created the first time
  // that clinic mints a TEST api key. Partners' developers book against it. It is
  // a real Clinic row on purpose: every tenant-scoped query, the booking service
  // and the webhook outbox then isolate it for free. The ONE thing that must be
  // special-cased is outbound WhatsApp — see isSandboxClinic() in sandbox.service,
  // which suppresses sends so a test booking can never message a real person.
  isSandbox        Boolean       @default(false)
  sandboxOfId      String?       @unique
  sandboxOf        Clinic?       @relation("ClinicSandbox", fields: [sandboxOfId], references: [id], onDelete: Cascade)
  sandbox          Clinic?       @relation("ClinicSandbox")

  users            User[]
  patients         Patient[]
  doctors          Doctor[]
  appointments     Appointment[]
  waitlists        Waitlist[]
  aiConversations  AiConversation[]
  whatsAppLogs     WhatsAppLog[]
  notifications    Notification[]
  whatsAppChannels WhatsAppChannel[]
  whatsAppBindings WhatsAppPatientBinding[]

  @@index([plan])
  @@index([isSandbox])
}

// One WhatsApp Cloud API number per clinic. The `phoneNumberId` is the routing
// key Meta sends in every inbound webhook (`value.metadata.phone_number_id`), so
// an inbound message is bound to a clinic by looking it up here — NOT by env.
// Outbound sends for a clinic use THIS row's token + phoneNumberId, so each
// clinic messages from its own number. Tokens are stored encrypted-at-rest when
// WA_CHANNEL_ENC_KEY is set (AES-256-GCM), else as plaintext (dev/back-compat).
model WhatsAppChannel {
  id                 String   @id @default(cuid())
  clinicId           String
  // Meta Cloud API identifiers. phoneNumberId is the inbound routing key.
  phoneNumberId      String   @unique
  wabaId             String?
  // Owning Meta Business id (resolved from the WABA during Embedded Signup).
  businessId         String?
  displayPhoneNumber String?
  // Long-lived access token (encrypted when WA_CHANNEL_ENC_KEY is configured).
  accessToken        String   @db.Text
  // Per-channel webhook verification + HMAC secret (optional; falls back to env).
  appSecret          String?
  verifyToken        String?
  status             String   @default("ACTIVE") // ACTIVE | DISABLED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([phoneNumberId])
}

// Binds a patient's WhatsApp phone to the clinic they belong to, so that ONE
// shared platform number can serve many clinics: the patient's first message
// carries a clinic join code (from a QR/link), we record the binding here, and
// every later message routes to that clinic. All data stays clinic-scoped.
model WhatsAppPatientBinding {
  phone     String   @id // digits-only WhatsApp number
  clinicId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model User {
  id           String    @id @default(cuid())
  clinicId     String
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CLINIC_ADMIN)
  // Email verification gate for self-service signup. @default(true) so an additive
  // `db push` backfills EXISTING users as verified (never locks them out); new
  // self-service signups are created with emailVerified:false explicitly.
  emailVerified   Boolean   @default(true)
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  aiConversations AiConversation[]
  emailOtp        EmailOtp?

  @@index([clinicId])
  @@index([role])
}

// One active email OTP per user (hashed, never plaintext). Used for the signup
// email-verification gate. Short-lived (TTL) with an attempt cap and a resend
// cooldown enforced in otp.service.ts.
model EmailOtp {
  id        String   @id @default(cuid())
  userId    String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  lastSentAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Patient {
  id            String   @id @default(cuid())
  patientCode   String?  @unique
  clinicId      String
  name          String
  phone         String?
  language      String
  age           Int?
  gender        String?
  healthConcern String?  @db.Text
  source        String   @default("staff") // 'staff' (dashboard) | 'public' (self-registration)
  createdAt     DateTime @default(now())

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  waitlistEntry   Waitlist?
  aiConversations AiConversation[]

  @@index([clinicId])
  @@unique([clinicId, phone])
}

model Doctor {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  speciality   String
  experienceYears Int?
  email        String?
  phone        String?
  // Set when the doctor self-registers on the Doctor Portal. Null for doctors
  // created by an admin who haven't claimed a login yet.
  passwordHash String?

  clinic        Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  schedules     DoctorSchedule[]
  leaves        DoctorLeave[]

  @@index([clinicId])
  @@unique([clinicId, name])
}

// Recurring weekly availability for a doctor. One row per active weekday.
// Slots are generated from startTime→endTime in slotMinutes steps.
model DoctorSchedule {
  id          String  @id @default(cuid())
  clinicId    String
  doctorId    String
  dayOfWeek   Int      // 0 = Sunday … 6 = Saturday
  startTime   String   // "09:00" (24h, clinic local)
  endTime     String   // "17:00"
  slotMinutes Int      @default(30)
  isActive    Boolean  @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([clinicId])
  @@index([doctorId])
}

// Date-range time off; blocks availability for the doctor across the range.
model DoctorLeave {
  id        String   @id @default(cuid())
  clinicId  String
  doctorId  String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([clinicId, startDate, endDate])
}

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  doctorId        String
  patientId       String
  appointmentDate DateTime          @db.Date
  appointmentTime String
  status          AppointmentStatus @default(PENDING)
  // Audit trail for the completion workflow: when the consultation was marked
  // finished and which User (clinic staff) marked it. Null until COMPLETED.
  completedAt     DateTime?
  completedBy     String?

  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor   Doctor   @relation(fields: [doctorId], references: [id])
  patient  Patient  @relation(fields: [patientId], references: [id])
  reminders Reminder[]

  @@index([clinicId])
  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentDate])
  @@index([status])
  @@index([clinicId, appointmentDate, appointmentTime])
  // NOTE: a PARTIAL unique index "Appointment_active_slot_key" enforces one active
  // booking per (clinicId, doctorId, appointmentDate, appointmentTime) WHERE
  // status <> 'CANCELLED'. Prisma's schema language can't express the WHERE clause,
  // so it is created by scripts/applySlotUniqueIndex.ts (run after `prisma db push`).
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_COMPLETED
  // Operational/system alert surfaced to clinic admins (e.g. WhatsApp sending is
  // failing or the access token has expired so patients aren't getting replies).
  SYSTEM_ALERT
}

// Dashboard notifications (the bell / notification center). Written by the
// automation engine on booking and on approve/reject/reschedule so staff see
// activity that originated from the WhatsApp bot, not just their own actions.
model Notification {
  id            String           @id @default(cuid())
  clinicId      String
  type          NotificationType
  title         String
  body          String           @db.Text
  appointmentId String?
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, read])
  @@index([clinicId, createdAt])
}

model Waitlist {
  id       String         @id @default(cuid())
  clinicId String
  patientId String        @unique
  priority Int            @default(0)
  status   WaitlistStatus @default(WAITING)

  // What the patient was trying to book when no slot was available. Used to match
  // a freed slot to the right waiting patient (prefer same doctor / date).
  desiredDoctorId   String?
  desiredSpeciality String?
  desiredDate       DateTime? @db.Date

  // When a freed slot is auto-offered to this entry (status OFFERED), the exact
  // slot is parked here so a patient's "YES" reply can be booked automatically.
  offeredDoctorId String?
  offeredDate     DateTime? @db.Date
  offeredTime     String?
  // The 15-minute hold expiry for the current OFFER. A cron sweep moves an
  // expired offer on to the next waiting patient.
  offeredExpiresAt DateTime?

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([priority])
  @@index([status])
  @@index([clinicId, status, priority])
}

model Reminder {
  id           String       @id @default(cuid())
  appointmentId String
  type         ReminderType
  sent         Boolean      @default(false)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // At most one reminder row per (appointment, type). This is the DB backstop
  // that lets the cron claim a reminder before sending so two overlapping runs
  // can never both fire the same reminder (P2002 on the loser).
  @@unique([appointmentId, type])
  @@index([type, sent])
}

// Scheduled WhatsApp medicine reminders, created from a MediScribe prescription.
// One row per (patient, drug) course; `times` are the clinic-local HH:MM slots it
// fires each day, `nextRunAt` is the next UTC instant to send. The cron claims a
// row via nextRunAt so overlapping runs never double-send. Owned by clinicId.
model MedicineReminder {
  id             String    @id @default(cuid())
  clinicId       String
  patientId      String
  phone          String
  consultationId String? // source MediScribe consultation (for regeneration)
  drug           String // human label, e.g. "Paracetamol 500mg — 1 tab after food"
  times          String[] // clinic-local HH:MM slots per day, e.g. ["09:00","21:00"]
  startDate      DateTime  @db.Date
  endDate        DateTime? @db.Date // null = open-ended
  nextRunAt      DateTime // next scheduled fire (true UTC instant)
  lastSentAt     DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([active, nextRunAt])
  @@index([clinicId, patientId])
  @@index([consultationId])
}

// Append-only PATIENT TIMELINE. Every meaningful action across the platform
// (registered, booked, reminded, visited, note finalized, prescribed, follow-up…)
// writes one row. Read three ways: the Healthcare Brain's patient context, the
// doctor's Patient Timeline UI, and the clinic's audit trail. Writes are
// fire-and-forget; scalars + indexes (no FK) mirror MedicineReminder so recording
// an event can never block or fail the action that produced it.
model PatientEvent {
  id        String   @id @default(cuid())
  clinicId  String
  patientId String
  // 'registered' | 'booked' | 'confirmed' | 'reminded' | 'no_show' | 'visited' |
  // 'note_finalized' | 'prescribed' | 'lab_ordered' | 'follow_up_set' |
  // 'refill_due' | 'message_in' | 'message_out'
  type      String
  title     String // human one-line, e.g. "Booked with Dr. Mehra — Tue 10:00 AM"
  detail    String?  @db.Text
  actorType String   @default("system") // 'patient' | 'doctor' | 'staff' | 'system'
  actorName String?
  refType   String? // 'appointment' | 'consultation' | 'prescription' | 'reminder'
  refId     String?
  meta      Json?
  at        DateTime @default(now())

  @@index([clinicId, patientId, at])
  @@index([clinicId, at])
}

enum AiMessageRole {
  USER
  ASSISTANT
}

model AiConversation {
  id        String      @id @default(cuid())
  clinicId  String
  userId    String?
  patientId String?
  channel   String      @default("dashboard") // 'dashboard' (staff) | 'whatsapp' (patient)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  clinic   Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user     User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient  Patient?    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([clinicId])
  @@index([userId])
  @@index([patientId])
}

model AiMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String        @db.Text
  createdAt      DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model WhatsAppLog {
  id          String   @id @default(cuid())
  clinicId    String?
  to          String
  messageType String
  body        String   @db.Text
  waMessageId String?
  status      String   @default("sent")
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([to])
  @@index([createdAt])
  @@index([waMessageId])
}

// One row per inbound patient turn through the WhatsApp receptionist. Captures
// the patient message, what the AI/keyword layer understood (intent +
// confidence + extracted speciality), the FSM state transition it drove, and the
// terminal booking action (if any). This is the audit trail for "AI understood X
// → FSM moved A→B → did Y". The AI NEVER acts directly; this records that the FSM
// owned every transition. Writes are best-effort and never block a reply.
model WhatsAppAudit {
  id           String   @id @default(cuid())
  phone        String
  clinicId     String?
  patientId    String?
  message      String   @db.Text
  intent       String?
  confidence   Float?
  speciality   String?
  fsmStateFrom String?
  fsmStateTo   String?
  action       String?
  // 'ai' (LLM understanding), 'deterministic' (keyword fallback), or 'fsm'
  // (in-flow numbered/interactive selection, no fresh understanding this turn).
  source       String   @default("fsm")
  createdAt    DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([phone])
}

// Tracks the recipient's last inbound message so we know whether the 24h
// WhatsApp customer-service (session) window is open for free-form replies.
// Re-keyed on (clinicId, phone): the SAME patient phone messaging two clinics is
// two independent windows — one clinic's inbound can never open another clinic's
// send window. clinicId is a scalar (no relation) to match WhatsAppSession.
model WhatsAppConversation {
  id            String   @id @default(cuid())
  clinicId      String
  phone         String
  lastInboundAt DateTime
  updatedAt     DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([clinicId, phone])
}

// Deterministic booking state machine state, one row per patient phone. The
// WhatsApp receptionist (whatsapp.booking.ts) is a finite state machine — the
// LLM is NOT in the control loop — so the patient's place in the flow plus the
// options last shown to them must survive between messages. `state` is the FSM
// node (IDLE, SPECIALITY_SELECTION, DOCTOR_SELECTION, SLOT_SELECTION,
// CONFIRMATION, …) and `data` is a JSON blob (stored as text to avoid Prisma
// Json default quirks) holding the chosen speciality/doctor, the exact numbered
// options last presented, slot pagination offset and the selected slot.
// Deterministic booking FSM state, one row per (clinic, patient phone). Re-keyed
// on (clinicId, phone) so the SAME patient phone has an INDEPENDENT booking flow
// per clinic — clinic A's session can never be read or overwritten by clinic B.
model WhatsAppSession {
  id        String   @id @default(cuid())
  phone     String
  clinicId  String
  patientId String?
  state     String   @default("IDLE")
  data      String   @default("{}") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([phone])
  @@index([clinicId])
}

// ─── Healthcare MCP (core/mcp) ───────────────────────────────────────────────
// CHANNEL-AGNOSTIC conversation session for the platform brain. Unlike
// WhatsAppSession (phone-keyed, WhatsApp-only), this is keyed on the shared
// patient identity + channel, so the SAME patient continues one logical thread
// across WhatsApp today and Voice/Web/Mobile later. Holds which skill is active
// and its brain-managed state. Additive, standalone table — it does NOT modify
// any existing model. Tenant-scoped by clinicId (registered in TENANT_MODELS).
model ConversationSession {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String
  channel     String   @default("whatsapp")
  activeSkill String?
  data        String   @default("{}") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clinicId, patientId, channel])
  @@index([clinicId])
  @@index([patientId])
}

// ─── NovaScribe (products/novascribe) ────────────────────────────────────────
// Doctor's AI scribe. Additive, standalone table: references appointment /
// patient / doctor by id (plain Strings, NOT formal relations) so adding it does
// NOT modify any existing model — purely a new table. Tenant-scoped by clinicId
// (registered in TENANT_MODELS).

enum ConsultationNoteStatus {
  AWAITING_AUDIO // opened (manually or on appointment.completed); no audio yet
  PROCESSING     // audio received; STT + AI pipeline running (async job)
  DRAFTED        // AI produced a SOAP + prescription draft from the transcript
  REVIEWED       // doctor edited the draft
  FINALIZED      // doctor approved & locked it (immutable)
  FAILED         // pipeline failed; see errorMessage (doctor can retry)
}

// ─── NovaScribe v2 generic document store ────────────────────────────────────
// One table backs all NovaScribe collections (patients, consultations, reports,
// prescriptions, transcripts) as JSON documents keyed by an app-provided string
// id, scoped per clinic. Mirrors the reference app's id-keyed repository model on
// Postgres without modelling every clinical sub-field as a column.
model NovaDoc {
  clinicId   String
  collection String // 'patients' | 'consultations' | 'reports' | 'prescriptions' | 'transcripts'
  id         String // app-provided id (e.g. con-..., pat-...)
  // Denormalised from data.patientId so patient-history can index/query by it.
  patientId  String?
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([clinicId, collection, id])
  @@index([clinicId, collection, updatedAt])
  @@index([clinicId, collection, patientId])
}

model ConsultationNote {
  id            String                 @id @default(cuid())
  clinicId      String
  appointmentId String?
  patientId     String?
  doctorId      String?
  patientName   String?
  doctorName    String?

  status        ConsultationNoteStatus @default(AWAITING_AUDIO)

  // --- Audio + STT pipeline -------------------------------------------------
  // Where the consultation audio is stored (storage-backend-relative key) and
  // the detected/declared language. errorMessage is set when status = FAILED.
  audioPath     String?
  language      String?
  durationSec   Int?
  errorMessage  String?                @db.Text

  transcript    String?                @db.Text
  // Diarized transcript segments: [{ speaker, text, startSec, endSec, confidence }].
  segments      Json?

  // Structured SOAP note (drafted by AI, editable by the doctor).
  subjective    String?                @db.Text
  objective     String?                @db.Text
  assessment    String?                @db.Text
  plan          String?                @db.Text
  // Prescription draft: array of { drug, dose, frequency, duration, notes, flagged }.
  prescription  Json?
  // Per-fact evidence/grounding spans for anti-hallucination review UI:
  // { field -> [{ quote, startSec?, confidence }] }. Lets the doctor see WHERE
  // in the transcript each generated fact came from.
  evidence      Json?

  reviewedBy    String?
  reviewedAt    DateTime?

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, appointmentId])
  @@index([clinicId, createdAt])
}

// ---------------------------------------------------------------------------
// External identity mapping (EMR integration). Links a ClinicBook LOCAL id to
// the id the same entity has in an external EMR/HMIS (OpenEMR/Epic/…), per
// clinic + system. Lets the EMR adapters translate between our ids and the
// EMR's for patients, doctors and appointments, so the rest of the app keeps
// using LOCAL ids only. Clinic-scoped at the app layer (in TENANT_MODELS);
// no FK relation kept, deliberately minimal.
// ---------------------------------------------------------------------------
model ExternalIdMap {
  id         String   @id @default(cuid())
  clinicId   String
  system     String // e.g. "openemr"
  entity     String // "patient" | "doctor" | "appointment"
  localId    String
  externalId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clinicId, system, entity, localId])
  @@unique([clinicId, system, entity, externalId])
  @@index([clinicId, system, entity])
}

// ---------------------------------------------------------------------------
// Public API keys. A partner system (hospital app / EMR / integrator) puts one
// of these in its own env and calls our /api/v1 surface; the key is what tells
// us WHICH clinic the request belongs to.
//
// Like WhatsAppChannel, this is a ROUTING/AUTH table looked up BEFORE a clinic
// is known, so it is deliberately NOT in TENANT_MODELS — resolution uses the raw
// prisma client. Management (list/revoke) filters by clinicId explicitly.
//
// Only the sha256 HASH of the key is stored; the plaintext is shown once at
// creation and never again (same discipline as a password).
// ---------------------------------------------------------------------------
// LIVE keys act on the clinic itself. TEST keys are issued against that clinic's
// paired SANDBOX clinic (Clinic.sandboxOfId), so a partner's developer books
// against throwaway data. Isolation is then the tenant engine's job rather than
// an `isTest` flag threaded through every appointment query.
enum ApiKeyMode {
  LIVE
  TEST
}

model ApiKey {
  id         String     @id @default(cuid())
  clinicId   String
  name       String
  keyHash    String     @unique
  prefix     String // e.g. "ck_live_a1b2c3" — safe to show in a UI list
  mode       ApiKeyMode @default(LIVE)
  // Coarse permissions: "read" gates GETs, "write" gates POST/PATCH. Defaults to
  // both, so every key issued before scopes existed keeps working unchanged.
  scopes     String[]   @default(["read", "write"])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  @@index([clinicId])
}

// ---------------------------------------------------------------------------
// Public-API idempotency. A partner retrying POST /api/v1/appointments after a
// timeout must not create a second booking: it replays the first result instead.
//
// A row is CLAIMED before the work starts (the @@unique makes two concurrent
// requests with the same key race for it — the loser gets 409 "in progress"),
// then stamped with the resulting appointmentId on success, or deleted on
// failure so the caller can legitimately retry.
//
// Clinic-scoped (in TENANT_MODELS): the key namespace belongs to the clinic, so
// two partners can pick the same key string without colliding.
// ---------------------------------------------------------------------------
model IdempotencyKey {
  id            String   @id @default(cuid())
  clinicId      String
  key           String
  endpoint      String // e.g. "POST /v1/appointments"
  appointmentId String? // set once the work succeeded; null while in flight
  createdAt     DateTime @default(now())

  @@unique([clinicId, key])
  @@index([clinicId, createdAt])
}

// ---------------------------------------------------------------------------
// Outbound webhooks. A partner registers a URL and we POST it every domain event
// it subscribed to, signed so the partner can prove the request came from us.
//
// `secret` is encrypted at rest with the same AES-256-GCM helper as
// WhatsAppChannel.accessToken (plaintext when no key is configured, dev only).
// We must be able to DECRYPT it (unlike an API key, which we only ever hash),
// because signing an outgoing request needs the plaintext.
// ---------------------------------------------------------------------------
model WebhookEndpoint {
  id        String   @id @default(cuid())
  clinicId  String
  url       String
  secret    String // encrypted at rest
  events    String[] // domain event names this endpoint wants
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([clinicId, enabled])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

// A TRANSACTIONAL OUTBOX row, not a fire-and-forget HTTP call. The event handler
// only writes this row; a cron drains it, so a partner being down (or a deploy
// mid-emit) delays delivery instead of losing it. Retried with exponential
// backoff, then parked as FAILED with the last error for support to inspect.
model WebhookDelivery {
  id            String                @id @default(cuid())
  clinicId      String
  endpointId    String
  event         String
  payload       Json
  status        WebhookDeliveryStatus @default(PENDING)
  attempts      Int                   @default(0)
  nextAttemptAt DateTime              @default(now())
  lastError     String?
  deliveredAt   DateTime?
  createdAt     DateTime              @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  // The cron scans across ALL clinics for what is due — this index is that query.
  @@index([status, nextAttemptAt])
  @@index([clinicId, createdAt])
}
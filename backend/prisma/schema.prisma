generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClinicPlan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum UserRole {
  ADMIN
  CLINIC_ADMIN
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum WaitlistStatus {
  WAITING
  OFFERED
  RESPONDED
  CONVERTED
  CANCELLED
}

enum ReminderType {
  BOOKING_CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  REMINDER_1H
  WAITLIST_OFFER
}

model Clinic {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  phone            String        @unique
  plan             ClinicPlan    @default(STARTER)
  stripeCustomerId String?       @unique
  createdAt        DateTime      @default(now())

  users            User[]
  patients         Patient[]
  doctors          Doctor[]
  appointments     Appointment[]
  waitlists        Waitlist[]
  aiConversations  AiConversation[]
  whatsAppLogs     WhatsAppLog[]
  notifications    Notification[]
  whatsAppChannels WhatsAppChannel[]

  @@index([plan])
}

// One WhatsApp Cloud API number per clinic. The `phoneNumberId` is the routing
// key Meta sends in every inbound webhook (`value.metadata.phone_number_id`), so
// an inbound message is bound to a clinic by looking it up here — NOT by env.
// Outbound sends for a clinic use THIS row's token + phoneNumberId, so each
// clinic messages from its own number. Tokens are stored encrypted-at-rest when
// WA_CHANNEL_ENC_KEY is set (AES-256-GCM), else as plaintext (dev/back-compat).
model WhatsAppChannel {
  id                 String   @id @default(cuid())
  clinicId           String
  // Meta Cloud API identifiers. phoneNumberId is the inbound routing key.
  phoneNumberId      String   @unique
  wabaId             String?
  // Owning Meta Business id (resolved from the WABA during Embedded Signup).
  businessId         String?
  displayPhoneNumber String?
  // Long-lived access token (encrypted when WA_CHANNEL_ENC_KEY is configured).
  accessToken        String   @db.Text
  // Per-channel webhook verification + HMAC secret (optional; falls back to env).
  appSecret          String?
  verifyToken        String?
  status             String   @default("ACTIVE") // ACTIVE | DISABLED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([phoneNumberId])
}

model User {
  id           String    @id @default(cuid())
  clinicId     String
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CLINIC_ADMIN)
  // Email verification gate for self-service signup. @default(true) so an additive
  // `db push` backfills EXISTING users as verified (never locks them out); new
  // self-service signups are created with emailVerified:false explicitly.
  emailVerified   Boolean   @default(true)
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  aiConversations AiConversation[]
  emailOtp        EmailOtp?

  @@index([clinicId])
  @@index([role])
}

// One active email OTP per user (hashed, never plaintext). Used for the signup
// email-verification gate. Short-lived (TTL) with an attempt cap and a resend
// cooldown enforced in otp.service.ts.
model EmailOtp {
  id        String   @id @default(cuid())
  userId    String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  lastSentAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Patient {
  id            String   @id @default(cuid())
  patientCode   String?  @unique
  clinicId      String
  name          String
  phone         String
  language      String
  age           Int?
  gender        String?
  healthConcern String?  @db.Text
  source        String   @default("staff") // 'staff' (dashboard) | 'public' (self-registration)
  createdAt     DateTime @default(now())

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  waitlistEntry   Waitlist?
  aiConversations AiConversation[]

  @@index([clinicId])
  @@unique([clinicId, phone])
}

model Doctor {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  speciality   String
  experienceYears Int?
  email        String?
  phone        String?
  // Set when the doctor self-registers on the Doctor Portal. Null for doctors
  // created by an admin who haven't claimed a login yet.
  passwordHash String?

  clinic        Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  schedules     DoctorSchedule[]
  leaves        DoctorLeave[]

  @@index([clinicId])
  @@unique([clinicId, name])
}

// Recurring weekly availability for a doctor. One row per active weekday.
// Slots are generated from startTime→endTime in slotMinutes steps.
model DoctorSchedule {
  id          String  @id @default(cuid())
  clinicId    String
  doctorId    String
  dayOfWeek   Int      // 0 = Sunday … 6 = Saturday
  startTime   String   // "09:00" (24h, clinic local)
  endTime     String   // "17:00"
  slotMinutes Int      @default(30)
  isActive    Boolean  @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([clinicId])
  @@index([doctorId])
}

// Date-range time off; blocks availability for the doctor across the range.
model DoctorLeave {
  id        String   @id @default(cuid())
  clinicId  String
  doctorId  String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([clinicId, startDate, endDate])
}

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  doctorId        String
  patientId       String
  appointmentDate DateTime          @db.Date
  appointmentTime String
  status          AppointmentStatus @default(PENDING)
  // Audit trail for the completion workflow: when the consultation was marked
  // finished and which User (clinic staff) marked it. Null until COMPLETED.
  completedAt     DateTime?
  completedBy     String?

  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor   Doctor   @relation(fields: [doctorId], references: [id])
  patient  Patient  @relation(fields: [patientId], references: [id])
  reminders Reminder[]

  @@index([clinicId])
  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentDate])
  @@index([status])
  @@index([clinicId, appointmentDate, appointmentTime])
  // NOTE: a PARTIAL unique index "Appointment_active_slot_key" enforces one active
  // booking per (clinicId, doctorId, appointmentDate, appointmentTime) WHERE
  // status <> 'CANCELLED'. Prisma's schema language can't express the WHERE clause,
  // so it is created by scripts/applySlotUniqueIndex.ts (run after `prisma db push`).
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_COMPLETED
  // Operational/system alert surfaced to clinic admins (e.g. WhatsApp sending is
  // failing or the access token has expired so patients aren't getting replies).
  SYSTEM_ALERT
}

// Dashboard notifications (the bell / notification center). Written by the
// automation engine on booking and on approve/reject/reschedule so staff see
// activity that originated from the WhatsApp bot, not just their own actions.
model Notification {
  id            String           @id @default(cuid())
  clinicId      String
  type          NotificationType
  title         String
  body          String           @db.Text
  appointmentId String?
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, read])
  @@index([clinicId, createdAt])
}

model Waitlist {
  id       String         @id @default(cuid())
  clinicId String
  patientId String        @unique
  priority Int            @default(0)
  status   WaitlistStatus @default(WAITING)

  // What the patient was trying to book when no slot was available. Used to match
  // a freed slot to the right waiting patient (prefer same doctor / date).
  desiredDoctorId   String?
  desiredSpeciality String?
  desiredDate       DateTime? @db.Date

  // When a freed slot is auto-offered to this entry (status OFFERED), the exact
  // slot is parked here so a patient's "YES" reply can be booked automatically.
  offeredDoctorId String?
  offeredDate     DateTime? @db.Date
  offeredTime     String?
  // The 15-minute hold expiry for the current OFFER. A cron sweep moves an
  // expired offer on to the next waiting patient.
  offeredExpiresAt DateTime?

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([priority])
  @@index([status])
  @@index([clinicId, status, priority])
}

model Reminder {
  id           String       @id @default(cuid())
  appointmentId String
  type         ReminderType
  sent         Boolean      @default(false)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // At most one reminder row per (appointment, type). This is the DB backstop
  // that lets the cron claim a reminder before sending so two overlapping runs
  // can never both fire the same reminder (P2002 on the loser).
  @@unique([appointmentId, type])
  @@index([type, sent])
}

enum AiMessageRole {
  USER
  ASSISTANT
}

model AiConversation {
  id        String      @id @default(cuid())
  clinicId  String
  userId    String?
  patientId String?
  channel   String      @default("dashboard") // 'dashboard' (staff) | 'whatsapp' (patient)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  clinic   Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user     User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient  Patient?    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([clinicId])
  @@index([userId])
  @@index([patientId])
}

model AiMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String        @db.Text
  createdAt      DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model WhatsAppLog {
  id          String   @id @default(cuid())
  clinicId    String?
  to          String
  messageType String
  body        String   @db.Text
  waMessageId String?
  status      String   @default("sent")
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([to])
  @@index([createdAt])
  @@index([waMessageId])
}

// One row per inbound patient turn through the WhatsApp receptionist. Captures
// the patient message, what the AI/keyword layer understood (intent +
// confidence + extracted speciality), the FSM state transition it drove, and the
// terminal booking action (if any). This is the audit trail for "AI understood X
// → FSM moved A→B → did Y". The AI NEVER acts directly; this records that the FSM
// owned every transition. Writes are best-effort and never block a reply.
model WhatsAppAudit {
  id           String   @id @default(cuid())
  phone        String
  clinicId     String?
  patientId    String?
  message      String   @db.Text
  intent       String?
  confidence   Float?
  speciality   String?
  fsmStateFrom String?
  fsmStateTo   String?
  action       String?
  // 'ai' (LLM understanding), 'deterministic' (keyword fallback), or 'fsm'
  // (in-flow numbered/interactive selection, no fresh understanding this turn).
  source       String   @default("fsm")
  createdAt    DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([phone])
}

// Tracks the recipient's last inbound message so we know whether the 24h
// WhatsApp customer-service (session) window is open for free-form replies.
// Re-keyed on (clinicId, phone): the SAME patient phone messaging two clinics is
// two independent windows — one clinic's inbound can never open another clinic's
// send window. clinicId is a scalar (no relation) to match WhatsAppSession.
model WhatsAppConversation {
  id            String   @id @default(cuid())
  clinicId      String
  phone         String
  lastInboundAt DateTime
  updatedAt     DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([clinicId, phone])
}

// Deterministic booking state machine state, one row per patient phone. The
// WhatsApp receptionist (whatsapp.booking.ts) is a finite state machine — the
// LLM is NOT in the control loop — so the patient's place in the flow plus the
// options last shown to them must survive between messages. `state` is the FSM
// node (IDLE, SPECIALITY_SELECTION, DOCTOR_SELECTION, SLOT_SELECTION,
// CONFIRMATION, …) and `data` is a JSON blob (stored as text to avoid Prisma
// Json default quirks) holding the chosen speciality/doctor, the exact numbered
// options last presented, slot pagination offset and the selected slot.
// Deterministic booking FSM state, one row per (clinic, patient phone). Re-keyed
// on (clinicId, phone) so the SAME patient phone has an INDEPENDENT booking flow
// per clinic — clinic A's session can never be read or overwritten by clinic B.
model WhatsAppSession {
  id        String   @id @default(cuid())
  phone     String
  clinicId  String
  patientId String?
  state     String   @default("IDLE")
  data      String   @default("{}") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([phone])
  @@index([clinicId])
}
# ClinicBook AI backend — environment template.
# Copy to backend/.env for local dev, or set these as Railway service variables
# for production. NEVER commit a filled-in .env (it is gitignored).

# ----- Core -----
NODE_ENV=production
# Railway injects PORT automatically in production. For local dev set it yourself.
PORT=5000

# ----- Database (Supabase / PostgreSQL) -----
# DATABASE_URL: pooled connection (PgBouncer, port 6543) used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used by `prisma db push` for schema sync.
# Supabase: Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# ----- Auth -----
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins, or * to allow all.
# In production set this to your deployed frontend URL.
CORS_ORIGIN=https://your-frontend.example.com

# Public base URL the backend is reachable at (tunnel / Railway domain). Used to
# print the WhatsApp webhook URL on startup and report it at GET /api/whatsapp/debug.
# Must match the Callback URL configured in Meta. Leave unset for local dev.
PUBLIC_BASE_URL=https://your-backend.up.railway.app

# ----- WhatsApp Cloud API (Meta) -----
WHATSAPP_TOKEN=replace-with-meta-cloud-api-token
PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-whatsapp-business-account-id
# Arbitrary string you also paste into Meta's webhook "Verify token" field.
VERIFY_TOKEN=replace-with-webhook-verify-token
# Meta App Secret (App Settings -> Basic). Required in production to enforce
# inbound webhook HMAC signature verification.
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
# Clinic id that owns the WhatsApp number — all inbound patient chats bind here.
WHATSAPP_CLINIC_ID=replace-with-clinic-id
# Symmetric key to encrypt per-clinic WhatsApp tokens at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Strongly recommended in production before clinics onboard their own numbers.
WA_CHANNEL_ENC_KEY=replace-with-32-byte-random-hex

# ----- Meta Embedded Signup (one-click per-clinic WhatsApp onboarding) -----
# Platform-level, set ONCE. See docs/integrations/whatsapp-embedded-signup.md.
# META_APP_ID: Facebook App id (public; used by the front-end SDK).
# META_APP_SECRET: app secret for the server-side code exchange (defaults to
#   WHATSAPP_APP_SECRET when omitted — same Meta app).
# META_CONFIG_ID: the Embedded Signup configuration id from the Meta App dashboard.
META_APP_ID=replace-with-facebook-app-id
META_APP_SECRET=replace-with-meta-app-secret
META_CONFIG_ID=replace-with-embedded-signup-config-id
META_GRAPH_VERSION=v20.0

# ----- Transactional email (Resend) for signup OTP verification -----
# When RESEND_API_KEY is unset, the OTP is logged to the server console instead of
# emailed (local dev).
# EMAIL_FROM MUST be on a domain you've verified in Resend (Domains -> Add Domain
# -> add the DKIM/SPF DNS records). Until a domain is verified, the Resend test
# sender "onboarding@resend.dev" only delivers to your own Resend account email.
# Production (clinicbook.ai verified): set EMAIL_FROM=ClinicBook AI <noreply@clinicbook.ai>
# See docs/integrations/email-setup.md.
RESEND_API_KEY=
EMAIL_FROM=ClinicBook AI <noreply@clinicbook.ai>

# ----- OpenAI (AI booking agent) -----
OPENAI_API_KEY=replace-with-openai-api-key

# ----- WhatsApp AI Receptionist (all default OFF; live FSM unchanged until on) -----
# Natural-language understanding layer in front of the deterministic FSM
# (intent/speciality/date/doctor extraction, FAQs, returning-patient memory,
# confidence-based clarify/handoff). Needs OPENAI_API_KEY; falls back to the
# deterministic keyword classifier when off/unkeyed.
WA_AI_RECEPTIONIST=false
# Render replies as WhatsApp interactive buttons / list messages (vs numbered text).
WA_INTERACTIVE=false
# Below this confidence (0..1) the receptionist asks to clarify / offers a human
# instead of guessing the intent.
WA_AI_CONFIDENCE_MIN=0.6
# Voice notes: patients can send a WhatsApp voice message; it is transcribed
# (OpenAI Whisper) and routed through AI understanding even when WA_AI_RECEPTIONIST
# is off for typed text. Needs OPENAI_API_KEY. Values:
#   blank or "*"/"all" → enabled for EVERYONE (default)
#   comma-separated numbers (matched on last 10 digits) → only those numbers
#   "off" → feature disabled
WA_VOICE_TEST_NUMBERS=
# Whisper language hint for voice notes (ISO-639-1). Short Hindi/Hinglish clips
# auto-detect badly (Whisper picks Urdu and mis-hears words), so we pin "hi" by
# default. Set "en" for English clinics, or blank to let Whisper auto-detect.
WA_VOICE_LANGUAGE=hi

# ----- Stripe (optional, billing) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

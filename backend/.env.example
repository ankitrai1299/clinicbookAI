# ClinicBook AI backend — environment template.
# Copy to backend/.env for local dev, or set these as Railway service variables
# for production. NEVER commit a filled-in .env (it is gitignored).

# ----- Core -----
NODE_ENV=production
# Railway injects PORT automatically in production. For local dev set it yourself.
PORT=5000

# ----- Database (Supabase / PostgreSQL) -----
# DATABASE_URL: pooled connection (PgBouncer, port 6543) used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used by `prisma db push` for schema sync.
# Supabase: Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# ----- Auth -----
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins, or * to allow all.
# In production set this to your deployed frontend URL.
CORS_ORIGIN=https://your-frontend.example.com

# Public base URL the backend is reachable at (tunnel / Railway domain). Used to
# print the WhatsApp webhook URL on startup and report it at GET /api/whatsapp/debug.
# Must match the Callback URL configured in Meta. Leave unset for local dev.
PUBLIC_BASE_URL=https://your-backend.up.railway.app

# ----- WhatsApp Cloud API (Meta) -----
WHATSAPP_TOKEN=replace-with-meta-cloud-api-token
PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-whatsapp-business-account-id
# Arbitrary string you also paste into Meta's webhook "Verify token" field.
VERIFY_TOKEN=replace-with-webhook-verify-token
# Meta App Secret (App Settings -> Basic). Required in production to enforce
# inbound webhook HMAC signature verification.
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
# Clinic id that owns the WhatsApp number — all inbound patient chats bind here.
WHATSAPP_CLINIC_ID=replace-with-clinic-id

# ----- OpenAI (AI booking agent) -----
OPENAI_API_KEY=replace-with-openai-api-key

# ----- Stripe (optional, billing) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
